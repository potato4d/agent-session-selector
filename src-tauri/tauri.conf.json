{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Session Selector",
  "version": "0.1.0",
  "identifier": "com.mail.agent-session-selector",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://127.0.0.1:6814",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:client"
  },
  "mainBinaryName": "agent-session-selector",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Session Selector",
        "center": true,
        "width": 500,
        "height": 860,
        "minWidth": 500,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
